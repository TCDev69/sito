---
/**
 * GiscusComments.astro
 *
 * Integrazione Giscus per commenti GitHub Discussions.
 *
 * Setup richiesto (una tantum):
 * 1. Vai su https://giscus.app
 * 2. Inserisci il tuo repository (es. TCDev/sito)
 * 3. Abilita GitHub Discussions nel repository
 * 4. Scegli category (consigliata: "Announcements" o una custom "Comments")
 * 5. Copia i valori data-repo, data-repo-id, data-category, data-category-id
 * 6. Inseriscili nelle variabili sotto (o in env).
 *
 * Documentazione: https://giscus.app
 */

interface Props {
  term: string;
  mapping?: 'pathname' | 'url' | 'title' | 'og:title' | 'specific' | 'number';
}

const {
  term,
  mapping = 'pathname',
} = Astro.props;

// ============================================================
// CONFIGURA QUI il tuo Giscus (o usa variabili env)
// ============================================================
const GISCUS_REPO        = import.meta.env.PUBLIC_GISCUS_REPO        || 'tuousername/tuorepo';
const GISCUS_REPO_ID     = import.meta.env.PUBLIC_GISCUS_REPO_ID     || 'INSERISCI_REPO_ID';
const GISCUS_CATEGORY    = import.meta.env.PUBLIC_GISCUS_CATEGORY    || 'Comments';
const GISCUS_CATEGORY_ID = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID || 'INSERISCI_CATEGORY_ID';
// ============================================================

const isConfigured = GISCUS_REPO !== 'tuousername/tuorepo';
---

<section class="comments-section" aria-labelledby="comments-heading">
  <div class="comments-header">
    <div class="comments-header-left">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      <h2 id="comments-heading" class="comments-title">Commenti</h2>
    </div>
    <span class="comments-badge">via GitHub Discussions</span>
  </div>

  {!isConfigured ? (
    <div class="comments-placeholder">
      <div class="placeholder-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <p class="placeholder-title">Commenti non configurati</p>
      <p class="placeholder-desc">
        Segui le istruzioni in <code>src/components/GiscusComments.astro</code> oppure
        imposta le variabili <code>PUBLIC_GISCUS_*</code>.
      </p>
      <a href="https://giscus.app" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
        Configura Giscus
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>
  ) : (
    <div class="giscus-wrap" id="giscus-container">
      <script
        src="https://giscus.app/client.js"
        data-repo={GISCUS_REPO}
        data-repo-id={GISCUS_REPO_ID}
        data-category={GISCUS_CATEGORY}
        data-category-id={GISCUS_CATEGORY_ID}
        data-mapping={mapping}
        data-term={mapping === 'specific' ? term : undefined}
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="dark_dimmed"
        data-lang="it"
        data-loading="lazy"
        crossorigin="anonymous"
        async
      ></script>
    </div>
  )}
</section>

<style>
  .comments-section {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border-muted);
  }

  .comments-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .comments-header-left {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-primary);
  }
  .comments-title {
    font-size: 1.0625rem;
    font-weight: 600;
    margin: 0;
  }
  .comments-badge {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background: var(--color-bg-elevated, rgba(255,255,255,.06));
    border: 1px solid var(--color-border-muted);
    padding: 0.25em 0.625em;
    border-radius: var(--radius-full);
  }

  /* Placeholder */
  .comments-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-10) var(--space-8);
    background: var(--color-bg-surface);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
    text-align: center;
  }
  .placeholder-icon {
    width: 52px; height: 52px;
    border-radius: var(--radius-full);
    background: rgba(255,255,255,.05);
    border: 1px solid var(--color-border-muted);
    display: flex; align-items: center; justify-content: center;
    color: var(--color-text-muted);
  }
  .placeholder-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }
  .placeholder-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    max-width: 420px;
    line-height: 1.6;
  }
  .placeholder-desc code {
    font-size: 0.8em;
    background: rgba(255,255,255,.07);
    border: 1px solid var(--color-border-muted);
    padding: 0.15em 0.45em;
    border-radius: var(--radius-sm);
    color: var(--color-blue-300, #79c0ff);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .giscus-wrap {
    min-height: 200px;
  }
</style>
