---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/foto', label: 'Foto' },
  // { href: '/blog', label: 'Blog' },
  // { href: '/projects', label: 'Progetti' },
];

const externalLinks = [
  { href: '/go/multitool', label: 'MultiTool', icon: 'tool' },
  { href: '/go/api', label: 'API', icon: 'api' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="nav-header" role="banner">
  <div class="container nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="TCDev - Home">
      <span class="logo-text">TC<span class="logo-accent">Dev</span></span>
    </a>

    <!-- Main nav links -->
    <nav class="nav-links" aria-label="Navigazione principale">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`nav-link ${isActive(item.href) ? 'active' : ''}`}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- External links + actions -->
    <div class="nav-actions">
      {externalLinks.map((link) => (
        <a
          href={link.href}
          class="nav-external btn btn-ghost"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Apri ${link.label}`}
        >
          {link.icon === 'tool' && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
            </svg>
          )}
          {link.icon === 'api' && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
          )}
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile hamburger -->
    <button
      class="nav-hamburger"
      id="nav-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Apri menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" role="navigation" aria-label="Menu mobile">
    <div class="mobile-menu-inner container">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`mobile-link ${isActive(item.href) ? 'active' : ''}`}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
      <div class="mobile-divider"></div>
      {externalLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-link mobile-link-external"
          target="_blank"
          rel="noopener noreferrer"
        >
          {link.label}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</header>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border-muted);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    height: 60px;
  }

  /* Logo */
  .nav-logo {
    flex-shrink: 0;
    text-decoration: none;
  }
  .logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
  }
  .logo-accent { color: var(--color-blue-400); }

  /* Nav links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    margin-left: var(--space-2);
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    padding: 0.375em 0.75em;
    border-radius: var(--radius-md);
    transition: color var(--transition-fast), background var(--transition-fast);
    text-decoration: none;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text-primary);
    background: var(--color-bg-elevated);
  }
  .nav-link.active { color: var(--color-blue-400); }

  /* Actions */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-left: auto;
  }

  .nav-external {
    font-size: 0.8rem;
    padding: 0.4em 0.875em;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    border-radius: var(--radius-sm);
    margin-left: auto;
  }
  .nav-hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-text-secondary);
    border-radius: 2px;
    transition: all var(--transition-fast);
  }

  /* Lang toggle */

  /* Mobile lang toggle */

  /* Mobile menu */
  .mobile-menu {
    display: none;
    border-top: 1px solid var(--color-border-muted);
  }
  .mobile-menu.open { display: block; }
  .mobile-menu-inner { padding-block: var(--space-4); }

  .mobile-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    padding: var(--space-3) var(--space-2);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: color var(--transition-fast), background var(--transition-fast);
  }
  .mobile-link:hover,
  .mobile-link.active { color: var(--color-text-primary); background: var(--color-bg-elevated); }
  .mobile-link.active { color: var(--color-blue-400); }
  .mobile-link-external { color: var(--color-text-muted); font-size: 0.875rem; }

  .mobile-divider {
    border-top: 1px solid var(--color-border-muted);
    margin-block: var(--space-3);
  }

  @media (max-width: 768px) {
    .nav-links,
    .nav-actions { display: none; }
    .nav-hamburger { display: flex; }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Chiudi menu' : 'Apri menu');
  });
</script>
