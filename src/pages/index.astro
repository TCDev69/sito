---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', (e) => !e.data.draft);
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const recentProjects = allProjects
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const displayProjects = featuredProjects.length > 0 ? featuredProjects : recentProjects;

const photoAlbums = [
  {
    id: 'gatti',
    name: 'Gatti',
    cover: '/images/portfolio/photo-1.jpg',
    photos: [
      { src: '/images/portfolio/photo-1.jpg', alt: 'Gatto 1' },
      { src: '/images/portfolio/photo-2.jpg', alt: 'Gatto 2' },
      { src: '/images/portfolio/photo-3.jpg', alt: 'Gatto 3' },
      { src: '/images/portfolio/photo-4.jpg', alt: 'Gatto 4' },
      { src: '/images/portfolio/photo-5.jpg', alt: 'Gatto 5' },
      { src: '/images/portfolio/photo-6.jpg', alt: 'Gatto 6' },
    ],
  },
];
---

<BaseLayout
  title="TCDev"
  description="Portfolio fotografico, blog e progetti di sviluppo software — TCDev"
>
  <!-- ===== HERO ================================================= -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text animate-fade-in">
        <h1 class="hero-title">
          <span>Sviluppo, creatività</span><br />
          <span class="hero-accent">e fotografia.</span>
        </h1>
        <p class="hero-description">
          Sviluppatore software, appassionato di fotografia e maker.
          Qui trovi il mio portfolio fotografico e i miei progetti open source.
        </p>
        <div class="hero-cta">
          <a href="/projects" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            <span>Progetti</span>
          </a>
          <a href="/foto" class="btn btn-ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            <span>Foto</span>
          </a>
          <!--<a href="/blog" class="btn btn-ghost">
            Blog
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>-->
        </div>
        <div class="hero-links">
          <a href="/go/multitool" class="hero-link" target="_blank" rel="noopener noreferrer">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            tools.tcdev.xyz
          </a>
          <a href="/go/api" class="hero-link" target="_blank" rel="noopener noreferrer">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            api.tcdev.xyz
          </a>
        </div>
      </div>

      <!-- Hero visual: logo blob -->
      <div class="hero-visual" aria-hidden="true">
        <div class="hero-blob">
          <img
            src="/logo.jpg"
            alt="TCDev"
            class="hero-blob-img"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            width="900"
            height="900"
            onerror="this.style.display='none'"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PORTFOLIO ALBUMS ==================================== -->
  <section class="section section-portfolio" aria-labelledby="portfolio-heading">
    <div class="container">
      <header class="section-header">
        <div>
          <h2 id="portfolio-heading" class="section-title">Portfolio Fotografico</h2>
          <p class="section-subtitle">Scatti dal mio archivio visivo.</p>
        </div>
        <a href="/foto" class="section-link">
          Vedi tutti
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </header>

      <div class="albums-grid">
        {photoAlbums.map((album) => (
          <button
            class="album-card"
            data-album={album.id}
            aria-label={`Apri album ${album.name} — ${album.photos.length} foto`}
          >
            <img
              src={album.cover}
              alt={`Album ${album.name}`}
              class="album-cover"
              loading="lazy"
              decoding="async"
              width="900"
              height="1350"
              onerror="this.closest('.album-card').classList.add('no-img')"
            />
            <div class="album-overlay">
              <span class="album-name">{album.name}</span>
              <span class="album-count">{album.photos.length} {album.photos.length === 1 ? 'foto' : 'foto'}</span>
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== LIGHTBOX =========================================== -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Visualizza foto" hidden>
    <button class="lightbox-close" id="lightbox-close" aria-label="Chiudi">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <button class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label="Foto precedente">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <div class="lightbox-content">
      <div class="lightbox-header" id="lightbox-header"></div>
      <img class="lightbox-img" id="lightbox-img" src="" alt="" />
      <p class="lightbox-counter" id="lightbox-counter"></p>
    </div>
    <button class="lightbox-nav lightbox-next" id="lightbox-next" aria-label="Foto successiva">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  </div>

  <!-- Albums data (injected for JS) -->
  <script id="albums-data" type="application/json" set:html={JSON.stringify(photoAlbums.map(a => ({ id: a.id, name: a.name, photos: a.photos })))}></script>

  <!-- ===== PROJECTS PREVIEW ==================================== -->
  <!--
  {displayProjects.length > 0 && (
    <section class="section" aria-labelledby="projects-heading">
      <div class="container">
        <header class="section-header">
          <h2 id="projects-heading" class="section-title">Progetti</h2>
          <a href="/projects" class="section-link">
            Vedi tutti
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </header>
        <div class="projects-grid">
          {displayProjects.map((project) => (
            <a href={`/projects/${project.slug}`} class="card project-card">
              {project.data.cover && (
                <img
                  src={project.data.cover}
                  alt={project.data.coverAlt ?? project.data.title}
                  class="project-card-img"
                  loading="lazy"
                  decoding="async"
                />
              )}
              <div class="project-card-body">
                <div class="project-card-header">
                  <h3 class="project-card-title">{project.data.title}</h3>
                  <span class={`status-dot status-${project.data.status}`} title={project.data.status}></span>
                </div>
                <p class="project-card-excerpt">{project.data.excerpt}</p>
                {project.data.stack.length > 0 && (
                  <div class="project-card-stack">
                    {project.data.stack.slice(0, 4).map((tech) => (
                      <span class="badge">{tech}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
  -->
  <!-- ===== CONTATTI =========================================== -->
  <section class="section section-contact" aria-labelledby="contact-heading">
    <div class="container">
      <header class="section-header">
        <div>
          <h2 id="contact-heading" class="section-title">Contatti</h2>
          <p class="section-subtitle">Trovami online.</p>
        </div>
      </header>
      <div class="contact-links">
        <!-- Email -->
        <a href="mailto:email@tcdev.xyz" class="contact-item">
          <div class="contact-icon contact-icon--email">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="2,4 12,13 22,4"/></svg>
          </div>
          <div class="contact-body">
            <span class="contact-label">Email</span>
            <span class="contact-value">email@tcdev.xyz</span>
          </div>
          <svg class="contact-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <!-- Instagram -->
        <a href="https://instagram.com/tcdev" class="contact-item" target="_blank" rel="noopener noreferrer">
          <div class="contact-icon contact-icon--instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </div>
          <div class="contact-body">
            <span class="contact-label">Instagram</span>
            <span class="contact-value">@tcdev</span>
          </div>
          <svg class="contact-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <!-- LinkedIn -->
        <a href="https://linkedin.com/in/tcdev0" class="contact-item" target="_blank" rel="noopener noreferrer">
          <div class="contact-icon contact-icon--linkedin">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </div>
          <div class="contact-body">
            <span class="contact-label">LinkedIn</span>
            <span class="contact-value">linkedin.com/in/tcdev0</span>
          </div>
          <svg class="contact-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <!-- GitHub -->
        <a href="https://github.com/TCDev69" class="contact-item" target="_blank" rel="noopener noreferrer">
          <div class="contact-icon contact-icon--github">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 0.5C5.37 0.5.5 5.37.5 12c0 5.08 3.29 9.4 7.86 10.93.57.1.78-.25.78-.56 0-.28-.01-1.02-.02-1.99-3.2.69-3.87-1.54-3.87-1.54-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.02 1.75 2.67 1.25 3.32.95.1-.75.4-1.25.73-1.54-2.56-.29-5.25-1.28-5.25-5.71 0-1.26.45-2.29 1.18-3.1-.12-.29-.52-1.46.11-3.05 0 0 .96-.31 3.15 1.18.92-.25 1.91-.37 2.89-.37.98 0 1.97.13 2.89.37 2.19-1.49 3.15-1.18 3.15-1.18.63 1.59.23 2.76.11 3.05.73.81 1.18 1.84 1.18 3.1 0 4.44-2.7 5.42-5.27 5.7.41.35.78 1.05.78 2.12 0 1.53-.01 2.76-.01 3.14 0 .31.21.67.79.56A10 10 0 0 0 23.5 12C23.5 5.37 18.63.5 12 .5z"/></svg>
          </div>
          <div class="contact-body">
            <span class="contact-label">GitHub</span>
            <span class="contact-value">github.com/TCDev69</span>
          </div>
          <svg class="contact-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    padding-top: clamp(3rem, 8vw, 7rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
    position: relative;
    overflow: hidden;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-12);
  }
  .hero-eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-blue-400);
    display: block;
    margin-bottom: var(--space-3);
  }
  .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: var(--space-6);
  }
  .hero-accent { color: var(--color-blue-400); }
  .hero-description {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    max-width: 520px;
    line-height: 1.75;
    margin-bottom: var(--space-8);
  }
  .hero-cta {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }
  .hero-links {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }
  .hero-link {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .hero-link:hover { color: var(--color-blue-400); }

  /* decorative blob */
  .hero-visual { position: relative; width: 260px; height: 260px; flex-shrink: 0; }
  .hero-blob {
    width: 260px; height: 260px;
    border-radius: 60% 40% 70% 30% / 50% 60% 40% 50%;
    background: radial-gradient(135deg, rgba(29,111,232,.22) 0%, rgba(29,111,232,.04) 70%);
    border: 1px solid rgba(29,111,232,.18);
    animation: blob-morph 8s ease-in-out infinite;
    overflow: hidden;
  }
  .hero-blob-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @keyframes blob-morph {
    0%,100% { border-radius: 60% 40% 70% 30% / 50% 60% 40% 50%; }
    33% { border-radius: 40% 60% 30% 70% / 60% 40% 60% 40%; }
    66% { border-radius: 70% 30% 50% 50% / 40% 70% 30% 60%; }
  }

  /* ---- Sections ---- */
  .section { padding-block: clamp(3rem, 6vw, 5rem); }
  .section + .section { padding-top: 0; }
  .section-portfolio { padding-bottom: clamp(1.5rem, 3vw, 2.5rem); }

  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: var(--space-8);
    gap: var(--space-4);
  }
  .section-title { font-size: clamp(1.25rem, 2.5vw, 1.75rem); }
  .section-subtitle {
    margin-top: var(--space-1);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }
  .section-link {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-blue-400);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .section-link:hover { color: var(--color-blue-300); }

  /* ---- Albums grid ---- */
  .albums-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-4);
  }

  .album-card {
    position: relative;
    aspect-ratio: 3/4;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    cursor: pointer;
    background: var(--color-bg-surface);
    padding: 0;
    transition: border-color var(--transition-fast), transform var(--transition-fast);
  }
  .album-card:hover { border-color: var(--color-blue-500); transform: translateY(-4px); }
  .album-card:focus-visible { outline: 2px solid var(--color-blue-400); outline-offset: 2px; }
  .album-card.no-img { background: linear-gradient(135deg, var(--color-bg-elevated), var(--color-bg-surface)); }

  .album-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .album-card:hover .album-cover { transform: scale(1.06); }

  .album-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.75) 0%, rgba(0,0,0,.1) 55%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-4);
    gap: var(--space-1);
    pointer-events: none;
  }
  .album-name {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
  }
  .album-count {
    font-size: 0.75rem;
    color: rgba(255,255,255,.6);
    font-weight: 500;
  }

  /* ---- Lightbox ---- */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 500;
    background: rgba(0,0,0,.92);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-8);
  }
  .lightbox[hidden] { display: none; }

  .lightbox-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    max-width: min(90vw, 1100px);
  }
  .lightbox-header {
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgba(255,255,255,.55);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .lightbox-img {
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
  }
  .lightbox-counter {
    font-size: 0.8125rem;
    color: rgba(255,255,255,.35);
  }
  .lightbox-close {
    position: fixed;
    top: var(--space-4); right: var(--space-4);
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: var(--radius-full);
    color: rgba(255,255,255,.8);
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background var(--transition-fast);
  }
  .lightbox-close:hover { background: rgba(255,255,255,.18); }
  .lightbox-nav {
    position: absolute;
    top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: var(--radius-full);
    color: rgba(255,255,255,.8);
    width: 48px; height: 48px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    transition: background var(--transition-fast);
  }
  .lightbox-nav:hover { background: rgba(255,255,255,.2); }
  .lightbox-prev { left: var(--space-4); }
  .lightbox-next { right: var(--space-4); }

  @media (max-width: 500px) {
    .lightbox-prev, .lightbox-next { display: none; }
  }

  /* ---- Projects grid ---- */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }
  .project-card-img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
  }
  .project-card-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }
  .project-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .project-card-title {
    font-size: 1.0625rem;
    font-weight: 600;
    transition: color var(--transition-fast);
  }
  .project-card:hover .project-card-title { color: var(--color-blue-400); }
  .project-card-excerpt {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    flex: 1;
  }
  .project-card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .status-active   { background: var(--color-green); }
  .status-completed{ background: var(--color-blue-400); }
  .status-wip      { background: var(--color-yellow); }
  .status-archived { background: var(--color-text-muted); }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
