---
import BaseLayout from '../layouts/BaseLayout.astro';

const portfolioPhotos = [
  { src: '/images/portfolio/photo-1.jpg', alt: 'Foto 1', caption: '', category: 'gatti' },
  { src: '/images/portfolio/photo-2.jpg', alt: 'Foto 2', caption: '', category: 'gatti' },
  { src: '/images/portfolio/photo-3.jpg', alt: 'Foto 3', caption: '', category: 'gatti' },
  { src: '/images/portfolio/photo-4.jpg', alt: 'Foto 4', caption: '', category: 'gatti' },
  { src: '/images/portfolio/photo-5.jpg', alt: 'Foto 5', caption: '', category: 'gatti' },
  { src: '/images/portfolio/photo-6.jpg', alt: 'Foto 6', caption: '', category: 'gatti' },
];

const photoCategories = ['tutti', ...Array.from(new Set(portfolioPhotos.map(p => p.category))).filter(Boolean)];
---

<BaseLayout
  title="Foto — TCDev"
  description="Portfolio fotografico — natura, paesaggi urbani, ritratti."
>
  <section class="section photos-hero">
    <div class="container">
      <h1 class="page-title">Fotografie</h1>
      <p class="page-subtitle">Una raccolta di scatti.</p>

      <div class="photo-filter" role="group" aria-label="Filtra per categoria">
        {photoCategories.map((cat) => (
          <button
            class={`filter-btn${cat === 'tutti' ? ' active' : ''}`}
            data-cat={cat}
          >
            {cat === 'tutti' ? 'Tutti' : cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="section photos-grid-section">
    <div class="container">
      <div class="photos-grid" id="photosGrid">
        {portfolioPhotos.map((photo) => (
          <button
            class="photo-item"
            data-src={photo.src}
            data-alt={photo.alt}
            data-cat={photo.category}
            aria-label={photo.alt}
          >
            <img src={photo.src} alt={photo.alt} loading="lazy" decoding="async" />
            {photo.caption && <span class="photo-caption">{photo.caption}</span>}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" aria-modal="true" role="dialog" aria-label="Anteprima foto" hidden>
    <button id="lbClose" class="lb-close" aria-label="Chiudi">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="lb-inner">
      <button id="lbPrev" class="lb-nav lb-prev" aria-label="Foto precedente">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <div class="lb-content">
        <img id="lbImg" src="" alt="" />
        <p id="lbCaption" class="lb-caption"></p>
      </div>
      <button id="lbNext" class="lb-nav lb-next" aria-label="Foto successiva">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .photos-hero {
    padding-top: clamp(2.5rem, 6vw, 4.5rem);
    padding-bottom: var(--space-6);
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    margin-bottom: var(--space-3);
  }

  .page-subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  /* ---- Filter pills ---- */
  .photo-filter {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 0.35em 0.9em;
    font-size: 0.8125rem;
    font-weight: 500;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    text-transform: capitalize;
    transition: border-color var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
  }

  .filter-btn:hover { border-color: var(--color-blue-500); color: var(--color-blue-400); }
  .filter-btn.active { background: var(--color-blue-500); border-color: var(--color-blue-500); color: #fff; }

  /* ---- Grid ---- */
  .photos-grid-section { padding-top: 0; }

  .photos-grid {
    columns: 3;
    column-gap: var(--space-4);
  }

  .photo-item {
    break-inside: avoid;
    display: block;
    position: relative;
    width: 100%;
    margin-bottom: var(--space-4);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    cursor: zoom-in;
    padding: 0;
  }

  .photo-item img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.3s ease, opacity 0.3s ease;
    opacity: 0.9;
  }

  .photo-item:hover img {
    transform: scale(1.03);
    opacity: 1;
  }

  .photo-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-3) var(--space-4);
    background: linear-gradient(transparent, rgba(0,0,0,.7));
    color: #fff;
    font-size: 0.8125rem;
    opacity: 0;
    transition: opacity 0.2s ease;
    text-align: left;
  }

  .photo-item:hover .photo-caption { opacity: 1; }

  @media (max-width: 900px) {
    .photos-grid { columns: 2; }
  }

  @media (max-width: 500px) {
    .photos-grid { columns: 1; }
  }

  /* ---- Lightbox ---- */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.93);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox[hidden] { display: none; }

  .lb-inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    width: 100%;
    max-width: min(95vw, 1300px);
    justify-content: center;
  }

  .lb-content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .lb-content img {
    max-width: 100%;
    max-height: 80vh;
    border-radius: var(--radius-lg);
    object-fit: contain;
  }

  .lb-caption {
    color: rgba(255,255,255,.65);
    font-size: 0.875rem;
    text-align: center;
  }

  .lb-close {
    position: fixed;
    top: var(--space-4);
    right: var(--space-4);
    z-index: 1001;
    color: rgba(255,255,255,.7);
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: var(--radius-full);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .lb-close:hover { background: rgba(255,255,255,.16); color: #fff; }

  .lb-nav {
    flex-shrink: 0;
    color: rgba(255,255,255,.7);
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: var(--radius-full);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .lb-nav:hover { background: rgba(255,255,255,.18); color: #fff; }

  @media (max-width: 640px) {
    .lb-prev, .lb-next { display: none; }
  }
</style>

<script>
  const grid = document.getElementById('photosGrid');
  const lightbox = document.getElementById('lightbox') as HTMLElement | null;
  const lbImg = document.getElementById('lbImg') as HTMLImageElement | null;
  const lbCaption = document.getElementById('lbCaption') as HTMLElement | null;
  const lbClose = document.getElementById('lbClose');
  const lbPrev = document.getElementById('lbPrev');
  const lbNext = document.getElementById('lbNext');

  let visibleItems: HTMLButtonElement[] = [];
  let currentIndex = 0;

  function getVisible(): HTMLButtonElement[] {
    return Array.from(
      document.querySelectorAll<HTMLButtonElement>('.photo-item')
    ).filter(el => el.style.display !== 'none');
  }

  function openLightbox(src: string, alt: string, caption: string) {
    if (!lightbox || !lbImg) return;
    lbImg.src = src;
    lbImg.alt = alt;
    if (lbCaption) lbCaption.textContent = caption;
    lightbox.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox?.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  function showIndex(i: number) {
    visibleItems = getVisible();
    if (!visibleItems.length) return;
    currentIndex = (i + visibleItems.length) % visibleItems.length;
    const item = visibleItems[currentIndex];
    openLightbox(item.dataset.src!, item.dataset.alt!, '');
  }

  grid?.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest('.photo-item') as HTMLButtonElement | null;
    if (!btn) return;
    visibleItems = getVisible();
    currentIndex = visibleItems.indexOf(btn);
    openLightbox(btn.dataset.src!, btn.dataset.alt!, '');
  });

  lbClose?.addEventListener('click', closeLightbox);
  lbPrev?.addEventListener('click', () => showIndex(currentIndex - 1));
  lbNext?.addEventListener('click', () => showIndex(currentIndex + 1));

  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox || lightbox.hasAttribute('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') showIndex(currentIndex - 1);
    if (e.key === 'ArrowRight') showIndex(currentIndex + 1);
  });

  // Touch swipe navigation
  let touchStartX = 0;
  let touchStartY = 0;

  lightbox?.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });

  lightbox?.addEventListener('touchend', (e) => {
    if (!lightbox || lightbox.hasAttribute('hidden')) return;
    const dx = e.changedTouches[0].clientX - touchStartX;
    const dy = e.changedTouches[0].clientY - touchStartY;
    if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
      if (dx < 0) showIndex(currentIndex + 1);
      else showIndex(currentIndex - 1);
    }
  }, { passive: true });

  // Category filter
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = btn.dataset.cat!;
      document.querySelectorAll<HTMLElement>('.photo-item').forEach((item) => {
        item.style.display = (cat === 'tutti' || item.dataset.cat === cat) ? '' : 'none';
      });
    });
  });
</script>
